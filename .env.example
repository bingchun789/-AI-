# Default is safe validation mode. With Binance testnet, false means it will place
# orders in the Binance futures simulated environment, not on real money.
DRY_RUN=true

# Poll Binance AI Select every 15 minutes.
POLL_INTERVAL_SECONDS=900
AI_SELECT_INTERVAL=1h

# "Strong Positive" threshold. Binance's current config marks >= 6.5 as strong buy.
SCORE_THRESHOLD=6.5

# Entry sizing and throttles.
USDT_PER_TRADE=100
MAX_NEW_POSITIONS_PER_CYCLE=999
MAX_TOTAL_OPEN_POSITIONS=999
MAX_LONG_OPEN_POSITIONS=999
MAX_SHORT_OPEN_POSITIONS=999
ENABLE_MIN_SIGNAL_COUNT_FILTER=true
MIN_SIGNAL_COUNT_TO_OPEN=6
COOLDOWN_MINUTES=10
LEVERAGE=2
MIN_QUOTE_VOLUME_24H_USDT=5000000
ENABLE_MARGIN_USAGE_CAP=false
MAX_MARGIN_USAGE_PCT=60
ENABLE_VOLATILITY_FILTER=true
VOLATILITY_INTERVAL=1h
VOLATILITY_LOOKBACK_BARS=4
MAX_SINGLE_BAR_RANGE_PCT=12
ENABLE_FUNDING_RATE_FILTER=true
MAX_ABS_FUNDING_RATE_PCT=0.10
ENABLE_CORRELATION_FILTER=false
CORRELATION_INTERVAL=1h
CORRELATION_LOOKBACK_BARS=24
CORRELATION_THRESHOLD=0.92
ENABLE_TREND_CONFIRMATION=false
TREND_INTERVAL=4h
TREND_MA_PERIOD=20
TREND_FALLBACK_INTERVALS=1h,15m,5m
ENABLE_TIME_EXIT=true
MAX_HOLD_HOURS=48
TIME_EXIT_MIN_PNL_PCT=5
ENABLE_STOP_LOSS=true
STOP_LOSS_PCT=32
ENABLE_PROFIT_LOCK=true
PROFIT_LOCK_TIERS=4:2,8:5,12:8
ENABLE_PROFIT_PROTECTION=true
PROFIT_PROTECTION_ACTIVATE_PCT=8
PROFIT_PROTECTION_TRAIL_PCT=3
ENABLE_SIGNAL_DROP_GUARD=true
SIGNAL_DROP_GUARD_RATIO=0.7
SIGNAL_DROP_GUARD_MIN_CANDIDATES=5
ENABLE_ACCOUNT_CIRCUIT_BREAKER=true
DAILY_LOSS_PAUSE_PCT=4
MAX_CONSECUTIVE_LOSSES=4
MAX_ACCOUNT_DRAWDOWN_PCT=12
CIRCUIT_BREAKER_COOLDOWN_MINUTES=120
ENABLE_RISK_POSITION_SIZING=true
RISK_PER_TRADE_PCT=0.6
MIN_NOTIONAL_PER_TRADE_USDT=100
MAX_NOTIONAL_PER_TRADE_USDT=100
ENABLE_PORTFOLIO_RISK_CAP=true
MAX_SIDE_OPEN_RISK_PCT=3
MAX_TOTAL_OPEN_RISK_PCT=5
MAX_CORRELATED_POSITIONS_PER_SIDE=2
ENABLE_BREAKEVEN_STOP=true
BREAKEVEN_TRIGGER_PCT=12
BREAKEVEN_BUFFER_PCT=1
ENABLE_PARTIAL_TAKE_PROFIT=true
PARTIAL_TAKE_PROFIT_TRIGGER_PCT=18
PARTIAL_TAKE_PROFIT_CLOSE_RATIO=0.5

# Skip instruments unless the broker can support this margin mode.
REQUIRED_MARGIN_MODE=CROSS
SKIP_IF_MARGIN_MODE_UNAVAILABLE=true

# Broker adapter: "mock" or "binance_testnet"
BROKER_ADAPTER=mock
BROKER_MARGIN_MODES=CROSS,ISOLATED
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Runtime files.
STATE_FILE=runtime/state.json
SNAPSHOT_FILE=runtime/strong_positive_snapshot.json
LOG_FILE=runtime/bot.log
ESTIMATED_TAKER_FEE_RATE=0.0005
MONITOR_INTERVAL_SECONDS=60
MONITOR_EVENT_DEDUP_SECONDS=600
